<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1>Euro 6 Vehicle Database</h1>
    <p><%= total.toLocaleString() %> vehicles</p>
  </div>
</div>

<!-- Filters -->
<form action="/vehicles" method="GET" class="filter-bar">
  <div class="form-group">
    <label>Manufacturer</label>
    <select name="manufacturer" class="form-control">
      <option value="">All manufacturers</option>
      <% manufacturers.forEach(function(m) { %>
        <option value="<%= m %>" <%= query.manufacturer === m ? 'selected' : '' %>><%= m %></option>
      <% }) %>
    </select>
  </div>
  <div class="form-group">
    <label>Fuel Type</label>
    <select name="fuelType" class="form-control">
      <option value="">All fuels</option>
      <% fuelTypes.forEach(function(f) { %>
        <option value="<%= f %>" <%= query.fuelType === f ? 'selected' : '' %>><%= f %></option>
      <% }) %>
    </select>
  </div>
  <button type="submit" class="btn btn-primary btn-sm" style="margin-bottom:0;">Filter</button>
  <a href="/vehicles" class="btn btn-secondary btn-sm" style="margin-bottom:0;">Reset</a>
</form>

<!-- Table -->
<div class="card">
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Manufacturer</th>
          <th>Model</th>
          <th>Fuel</th>
          <th>CO&#8322; (g/km)</th>
          <th>Engine (cc)</th>
          <th>Transmission</th>
        </tr>
      </thead>
      <tbody>
        <% if (vehicles.length === 0) { %>
          <tr><td colspan="6" style="text-align:center;padding:2rem;color:var(--text-muted);">No vehicles found</td></tr>
        <% } %>
        <% vehicles.forEach(function(v) { %>
          <tr>
            <td style="font-weight:500;color:var(--text-primary);"><%= v.manufacturer %></td>
            <td><%= v.model %></td>
            <td><span class="badge badge-default"><%= v.fuelType || 'N/A' %></span></td>
            <td style="font-weight:600;color:var(--aurora-teal);"><%= v.co2 || 'N/A' %></td>
            <td><%= v.engineSize || 'N/A' %></td>
            <td><%= v.transmission || 'N/A' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (page > 1) { %>
        <a href="/vehicles?page=<%= page-1 %>&manufacturer=<%= query.manufacturer||'' %>&fuelType=<%= query.fuelType||'' %>">&#8592; Prev</a>
      <% } %>
      <% for (var i = Math.max(1,page-2); i <= Math.min(totalPages,page+2); i++) { %>
        <a href="/vehicles?page=<%= i %>&manufacturer=<%= query.manufacturer||'' %>&fuelType=<%= query.fuelType||'' %>" class="<%= i===page?'active':'' %>"><%= i %></a>
      <% } %>
      <% if (page < totalPages) { %>
        <a href="/vehicles?page=<%= page+1 %>&manufacturer=<%= query.manufacturer||'' %>&fuelType=<%= query.fuelType||'' %>">Next &#8594;</a>
      <% } %>
      <span style="color:var(--text-muted);font-size:0.8rem;margin-left:0.5rem;">Page <%= page %> of <%= totalPages %></span>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
