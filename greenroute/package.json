{
  "name": "greenroute",
  "version": "2.0.0",
  "description": "Sustainable Urban Transport Platform — GreenRoute",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "seed:vehicles": "node scripts/seedVehicles.js",
    "seed:transport": "node scripts/seedTransportModes.js",
    "seed:all": "node scripts/seedTransportModes.js && node scripts/seedVehicles.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:verbose": "jest --forceExit --detectOpenHandles --verbose"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "connect-mongo": "^5.1.0",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mongoose": "^7.6.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.1",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
